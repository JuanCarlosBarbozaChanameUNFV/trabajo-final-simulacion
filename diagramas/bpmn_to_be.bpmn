<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_CallCenterTOBE"
                  targetNamespace="http://simulacion.unfv.edu.pe/bpmn">

  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_CallCenter" name="Call Center - Atención de Llamadas (TO-BE)" processRef="Process_AtencionLlamadas"/>
  </bpmn:collaboration>

  <bpmn:category id="Category_Fases">
    <bpmn:categoryValue id="CategoryValue_Fase1" value="Fase 1: Planificación y recepción"/>
    <bpmn:categoryValue id="CategoryValue_Fase2" value="Fase 2: Verificación y espera"/>
    <bpmn:categoryValue id="CategoryValue_Fase3" value="Fase 3: Atención"/>
    <bpmn:categoryValue id="CategoryValue_Fase4" value="Fase 4: Cálculo y cierre"/>
  </bpmn:category>

  <bpmn:process id="Process_AtencionLlamadas" name="Atención de Llamadas - TO-BE" isExecutable="false">

    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Cliente" name="Cliente">
        <bpmn:flowNodeRef>StartEvent_Cliente</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Supervisor" name="Supervisor / Planificación">
        <bpmn:flowNodeRef>StartEvent_Mes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VerificarMes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Temporada</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Activar5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Mantener4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DotacionConfirmada</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Sistema" name="Sistema / Central Telefónica">
        <bpmn:flowNodeRef>Task_Registrar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Disponible</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Cola</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Indicadores</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SLA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DentroSLA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FueraSLA</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Agente" name="Agente de Atención">
        <bpmn:flowNodeRef>Task_Atender</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Resolver</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Cierre</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:group id="Group_Fase1" categoryValueRef="CategoryValue_Fase1"/>
    <bpmn:group id="Group_Fase2" categoryValueRef="CategoryValue_Fase2"/>
    <bpmn:group id="Group_Fase3" categoryValueRef="CategoryValue_Fase3"/>
    <bpmn:group id="Group_Fase4" categoryValueRef="CategoryValue_Fase4"/>

    <!-- Cadena 1: planificacion mensual de dotacion (el cambio TO-BE) -->
    <bpmn:startEvent id="StartEvent_Mes" name="Inicio del mes de operación">
      <bpmn:outgoing>Flow_M1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_VerificarMes" name="Verificar mes de&#10;operación">
      <bpmn:incoming>Flow_M1</bpmn:incoming>
      <bpmn:outgoing>Flow_M2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Temporada" name="¿Es temporada alta&#10;(set-dic)?">
      <bpmn:incoming>Flow_M2</bpmn:incoming>
      <bpmn:outgoing>Flow_M3_Si</bpmn:outgoing>
      <bpmn:outgoing>Flow_M3_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_Activar5" name="Activar turno del 5.° agente&#10;(dotación = 5)">
      <bpmn:incoming>Flow_M3_Si</bpmn:incoming>
      <bpmn:outgoing>Flow_M4a</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Mantener4" name="Mantener dotación estándar&#10;(dotación = 4)">
      <bpmn:incoming>Flow_M3_No</bpmn:incoming>
      <bpmn:outgoing>Flow_M4b</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_DotacionConfirmada" name="Dotación de agentes&#10;confirmada para el periodo">
      <bpmn:incoming>Flow_M4a</bpmn:incoming>
      <bpmn:incoming>Flow_M4b</bpmn:incoming>
      <bpmn:outgoing>Flow_M5</bpmn:outgoing>
    </bpmn:task>

    <!-- Cadena 2: atencion de cada llamada (igual estructura que AS-IS) -->
    <bpmn:startEvent id="StartEvent_Cliente" name="Cliente realiza llamada">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_Registrar" name="Registrar llamada entrante&#10;(timestamp de llegada)">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Disponible" name="¿Hay agente disponible&#10;según dotación activa?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:incoming>Flow_M5</bpmn:incoming>
      <bpmn:outgoing>Flow_3_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_4_Si</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_Cola" name="Llamada ingresa a la cola de&#10;espera (riesgo reducido con&#10;dotación ajustada)">
      <bpmn:incoming>Flow_3_No</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Atender" name="Agente disponible&#10;atiende la llamada">
      <bpmn:incoming>Flow_4_Si</bpmn:incoming>
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Resolver" name="Agente resuelve la&#10;consulta del cliente">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Cierre" name="Agente registra cierre&#10;de llamada (timestamp fin)">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Indicadores" name="Sistema calcula indicadores&#10;(espera, servicio)">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_SLA" name="¿Espera ≤ 60&#10;segundos?">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10_Si</bpmn:outgoing>
      <bpmn:outgoing>Flow_11_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_DentroSLA" name="Marcar dentro del&#10;estándar (meets_standard=TRUE)">
      <bpmn:incoming>Flow_10_Si</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_FueraSLA" name="Marcar fuera del estándar&#10;(meets_standard=FALSE)">
      <bpmn:incoming>Flow_11_No</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_1" name="Llamada finalizada">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:incoming>Flow_13</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_M1" sourceRef="StartEvent_Mes" targetRef="Task_VerificarMes"/>
    <bpmn:sequenceFlow id="Flow_M2" sourceRef="Task_VerificarMes" targetRef="Gateway_Temporada"/>
    <bpmn:sequenceFlow id="Flow_M3_Si" name="Sí, set-dic" sourceRef="Gateway_Temporada" targetRef="Task_Activar5"/>
    <bpmn:sequenceFlow id="Flow_M3_No" name="No" sourceRef="Gateway_Temporada" targetRef="Task_Mantener4"/>
    <bpmn:sequenceFlow id="Flow_M4a" sourceRef="Task_Activar5" targetRef="Task_DotacionConfirmada"/>
    <bpmn:sequenceFlow id="Flow_M4b" sourceRef="Task_Mantener4" targetRef="Task_DotacionConfirmada"/>
    <bpmn:sequenceFlow id="Flow_M5" sourceRef="Task_DotacionConfirmada" targetRef="Gateway_Disponible"/>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_Cliente" targetRef="Task_Registrar"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Registrar" targetRef="Gateway_Disponible"/>
    <bpmn:sequenceFlow id="Flow_3_No" name="No" sourceRef="Gateway_Disponible" targetRef="Task_Cola"/>
    <bpmn:sequenceFlow id="Flow_4_Si" name="Sí" sourceRef="Gateway_Disponible" targetRef="Task_Atender"/>
    <bpmn:sequenceFlow id="Flow_5" name="Agente se libera" sourceRef="Task_Cola" targetRef="Task_Atender"/>
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_Atender" targetRef="Task_Resolver"/>
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_Resolver" targetRef="Task_Cierre"/>
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_Cierre" targetRef="Task_Indicadores"/>
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_Indicadores" targetRef="Gateway_SLA"/>
    <bpmn:sequenceFlow id="Flow_10_Si" name="Sí, ≤60s" sourceRef="Gateway_SLA" targetRef="Task_DentroSLA"/>
    <bpmn:sequenceFlow id="Flow_11_No" name="No, &gt;60s" sourceRef="Gateway_SLA" targetRef="Task_FueraSLA"/>
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_DentroSLA" targetRef="EndEvent_1"/>
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_FueraSLA" targetRef="EndEvent_1"/>

  </bpmn:process>

  <bpmndi:BPMNDiagram id="Diagram_1">
    <bpmndi:BPMNPlane id="Plane_1" bpmnElement="Collaboration_1">

      <bpmndi:BPMNShape id="Participant_CallCenter_di" bpmnElement="Participant_CallCenter" isHorizontal="true">
        <dc:Bounds x="40" y="40" width="2080" height="600"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Cliente_di" bpmnElement="Lane_Cliente" isHorizontal="true">
        <dc:Bounds x="70" y="40" width="2050" height="150"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Supervisor_di" bpmnElement="Lane_Supervisor" isHorizontal="true">
        <dc:Bounds x="70" y="190" width="2050" height="150"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Sistema_di" bpmnElement="Lane_Sistema" isHorizontal="true">
        <dc:Bounds x="70" y="340" width="2050" height="150"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Agente_di" bpmnElement="Lane_Agente" isHorizontal="true">
        <dc:Bounds x="70" y="490" width="2050" height="150"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Group_Fase1_di" bpmnElement="Group_Fase1">
        <dc:Bounds x="70" y="40" width="725" height="600"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Group_Fase2_di" bpmnElement="Group_Fase2">
        <dc:Bounds x="795" y="40" width="270" height="600"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Group_Fase3_di" bpmnElement="Group_Fase3">
        <dc:Bounds x="1065" y="40" width="520" height="600"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Group_Fase4_di" bpmnElement="Group_Fase4">
        <dc:Bounds x="1585" y="40" width="535" height="600"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_Mes_di" bpmnElement="StartEvent_Mes">
        <dc:Bounds x="110" y="247" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_VerificarMes_di" bpmnElement="Task_VerificarMes">
        <dc:Bounds x="190" y="225" width="110" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Temporada_di" bpmnElement="Gateway_Temporada">
        <dc:Bounds x="350" y="240" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Activar5_di" bpmnElement="Task_Activar5">
        <dc:Bounds x="440" y="195" width="140" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Mantener4_di" bpmnElement="Task_Mantener4">
        <dc:Bounds x="440" y="285" width="140" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DotacionConfirmada_di" bpmnElement="Task_DotacionConfirmada">
        <dc:Bounds x="630" y="225" width="140" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_Cliente_di" bpmnElement="StartEvent_Cliente">
        <dc:Bounds x="110" y="97" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Registrar_di" bpmnElement="Task_Registrar">
        <dc:Bounds x="630" y="375" width="110" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Disponible_di" bpmnElement="Gateway_Disponible">
        <dc:Bounds x="810" y="390" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Cola_di" bpmnElement="Task_Cola">
        <dc:Bounds x="910" y="365" width="130" height="100"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Atender_di" bpmnElement="Task_Atender">
        <dc:Bounds x="1090" y="525" width="130" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Resolver_di" bpmnElement="Task_Resolver">
        <dc:Bounds x="1260" y="525" width="130" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Cierre_di" bpmnElement="Task_Cierre">
        <dc:Bounds x="1430" y="525" width="130" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Indicadores_di" bpmnElement="Task_Indicadores">
        <dc:Bounds x="1600" y="375" width="130" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SLA_di" bpmnElement="Gateway_SLA">
        <dc:Bounds x="1780" y="390" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DentroSLA_di" bpmnElement="Task_DentroSLA">
        <dc:Bounds x="1880" y="280" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_FueraSLA_di" bpmnElement="Task_FueraSLA">
        <dc:Bounds x="1880" y="460" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="2060" y="97" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_M1_di" bpmnElement="Flow_M1">
        <di:waypoint x="146" y="265"/>
        <di:waypoint x="190" y="265"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_M2_di" bpmnElement="Flow_M2">
        <di:waypoint x="300" y="265"/>
        <di:waypoint x="350" y="265"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_M3_Si_di" bpmnElement="Flow_M3_Si">
        <di:waypoint x="375" y="240"/>
        <di:waypoint x="375" y="230"/>
        <di:waypoint x="440" y="230"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_M3_No_di" bpmnElement="Flow_M3_No">
        <di:waypoint x="375" y="290"/>
        <di:waypoint x="375" y="320"/>
        <di:waypoint x="440" y="320"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_M4a_di" bpmnElement="Flow_M4a">
        <di:waypoint x="580" y="230"/>
        <di:waypoint x="630" y="265"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_M4b_di" bpmnElement="Flow_M4b">
        <di:waypoint x="580" y="320"/>
        <di:waypoint x="630" y="285"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_M5_di" bpmnElement="Flow_M5">
        <di:waypoint x="700" y="305"/>
        <di:waypoint x="700" y="415"/>
        <di:waypoint x="810" y="415"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="146" y="115"/>
        <di:waypoint x="685" y="115"/>
        <di:waypoint x="685" y="375"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="740" y="415"/>
        <di:waypoint x="810" y="415"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_No_di" bpmnElement="Flow_3_No">
        <di:waypoint x="860" y="415"/>
        <di:waypoint x="910" y="415"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_Si_di" bpmnElement="Flow_4_Si">
        <di:waypoint x="835" y="440"/>
        <di:waypoint x="835" y="565"/>
        <di:waypoint x="1090" y="565"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="975" y="465"/>
        <di:waypoint x="975" y="565"/>
        <di:waypoint x="1090" y="565"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="1220" y="565"/>
        <di:waypoint x="1260" y="565"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="1390" y="565"/>
        <di:waypoint x="1430" y="565"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1560" y="565"/>
        <di:waypoint x="1665" y="565"/>
        <di:waypoint x="1665" y="455"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="1730" y="415"/>
        <di:waypoint x="1780" y="415"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_10_Si_di" bpmnElement="Flow_10_Si">
        <di:waypoint x="1805" y="390"/>
        <di:waypoint x="1805" y="320"/>
        <di:waypoint x="1880" y="320"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_11_No_di" bpmnElement="Flow_11_No">
        <di:waypoint x="1805" y="440"/>
        <di:waypoint x="1805" y="500"/>
        <di:waypoint x="1880" y="500"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="2020" y="320"/>
        <di:waypoint x="2078" y="320"/>
        <di:waypoint x="2078" y="133"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="2020" y="500"/>
        <di:waypoint x="2078" y="500"/>
        <di:waypoint x="2078" y="133"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
